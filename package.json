{
  "name": "the_application_name",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run build:common && bun run dev:backend & bun run dev:web & bun run dev:common",
    "typecheck": "bun run build:common && bun --filter '*' typecheck",
    "dev:backend": "bun --filter @the_application_name/backend dev",
    "dev:web": "bun --filter @the_application_name/web dev",
    "dev:common": "bun --filter @the_application_name/common dev",
    "build:backend": "bun --filter @the_application_name/backend build",
    "build:web": "bun --filter @the_application_name/web build",
    "build:common": "bun --filter @the_application_name/common build"
  }
}